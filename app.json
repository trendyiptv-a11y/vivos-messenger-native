{
  "expo": {
    "owner": "speednet19",
    "name": "VIVOS Messenger",
    "slug": "vivos-messenger-native",
    "scheme": "vivosmessenger",
    "version": "0.1.15",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#163865"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "app.vivos.messenger",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "VIVOS Messenger folosește camera pentru apeluri video.",
        "NSMicrophoneUsageDescription": "VIVOS Messenger folosește microfonul pentru apeluri audio și video."
      }
    },
    "android": {
      "package": "app.vivos.messenger",
      "versionCode": 22,
      "googleServicesFile": "./google-services.json",
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#163865"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-notifications",
      "./plugins/withVivosFullScreenCall",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Permite VIVOS Messenger să folosească camera pentru apeluri video.",
          "microphonePermission": "Permite VIVOS Messenger să folosească microfonul pentru apeluri audio și video."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "73f4e357-bdbb-4955-af78-21056bc94313"
      }
    }
  }
}
